[Unit]
Description=Khan Homeschool Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=chawkins
Group=chawkins
WorkingDirectory=/home/chawkins/.openclaw/workspace/khan-homeschool/backend
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/chawkins/.openclaw/workspace/khan-homeschool/backend/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8008
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
